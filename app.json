{
  "expo": {
    "name": "MediTriage AI",
    "slug": "meditriage-ai",
    "version": "1.0.0",
    "scheme": "meditriage",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F8FC"
    },
    "ios": {
      "infoPlist": {
        "NSMicrophoneUsageDescription": "MediTriage needs your microphone to record symptoms.",
        "NSCameraUsageDescription": "MediTriage needs camera access to capture symptoms.",
        "NSPhotoLibraryUsageDescription": "MediTriage needs photo library access to upload symptom images."
      }
    },
    "android": {
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "fonts": [
      "./assets/fonts/DMSans/DMSans-Regular.ttf",
      "./assets/fonts/DMSans/DMSans-Medium.ttf",
      "./assets/fonts/DMSans/DMSans-SemiBold.ttf",
      "./assets/fonts/DMSans/DMSans-Bold.ttf"
    ]
  }
}
